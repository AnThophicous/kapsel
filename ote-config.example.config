{
  "version": 1,
  "sandbox": {
    "enabled": true,
    "allowed_paths": ["./"],
    "denied_paths": [],
    "allowed_env": ["PATH", "SYSTEMROOT", "WINDIR", "HOME", "USERPROFILE", "TMP", "TEMP"]
  },
  "runtime": {
    "default_shell": "cmd",
    "execution_mode": "safe",
    "cache_dir": ".ote/cache"
  }
}

